# Never commit a real key. Copy this file to .env for local development.
F3_NATION_API_KEY=replace_with_new_key
F3_API_CLIENT=f3-midlands-site

# These names only select the official F3 organizations included on the site.
# All AO data is generated from F3 Nation.
F3_TARGET_ORG_NAMES=Lexington,Columbia,Lake Murray,Camden,Saluda

# Use IDs instead of names when an official organization name is ambiguous.
# F3_TARGET_ORG_IDS=123,456,789

F3_MIN_AO_COUNT=5
