# Never commit the real key. For GitHub Pages, store it as the
# repository Actions secret named F3_NATION_API_KEY.
F3_NATION_API_KEY=replace_with_a_new_f3_nation_api_key

# Optional overrides
F3_API_BASE_URL=https://api.f3nation.com/v1
F3_API_CLIENT=scalar-api
F3_REGION_NAMES=Lexington,Columbia,Lake Murray,Camden,Saluda
F3_MIN_AO_COUNT=20
F3_SYNC_STRICT=false
