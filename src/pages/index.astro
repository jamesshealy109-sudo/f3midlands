---
import '../styles/global.css';
import aos from '../data/aos.json';
const visibleAos = aos.filter((ao) => ao.showOnWebsite !== false && ao.active !== false && ao.verified !== false);

const regions = ['Lexington', 'Columbia', 'Lake Murray', 'Camden', 'Saluda'];
const types = [...new Set(visibleAos.map((ao) => ao.type))].sort();
const totalAos = visibleAos.length;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="F3 Midlands helps men find free outdoor workouts across Lexington, Columbia, Lake Murray, Camden, and Saluda." />
    <title>F3 Midlands | Free Outdoor Workouts for Men</title>
    <link
  rel="icon"
  type="image/png"
  sizes="512x512"
  href="/f3midlands/assets/f3-logo.png"
/>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="#top" aria-label="F3 Midlands home">
        <img src="/f3midlands/assets/f3-logo.png" alt="F3" />
        <span>F3 Midlands</span>
      </a>
      <nav aria-label="Primary navigation">
        <a href="#new">I'm New</a>
<a href="#today">Today</a>
<a href="#find">Find an AO</a>
<a href="#contact">Need Help?</a>
      </nav>
    </header>

    <main id="top">
      <section class="hero">
        <div class="hero-bg" aria-hidden="true"></div>
        <div class="hero-content">
          <div class="hero-mark" aria-hidden="true"><img src="/f3midlands/assets/f3-logo.png" alt="" /></div>
          <p class="eyebrow">Lexington • Columbia • Lake Murray • Camden • Saluda</p>
          <h1>Free outdoor workouts for men.</h1>
          <p class="lead">No fees. No signup. No excuses. Just show up in the gloom and get better with men in your community.</p>
          <div class="hero-actions">
            <a class="button primary" href="#new">Start Here</a>
	   <a class="button ghost" href="#today">Today’s Workouts</a>
          </div>
          <div class="stats" aria-label="F3 Midlands quick stats">
            <div><strong>{totalAos}</strong><span>AO listings</span></div>
            <div><strong>{regions.length}</strong><span>Regions</span></div>
            <div><strong>$0</strong><span>Cost</span></div>
            <div><strong>365</strong><span>Rain or shine</span></div>
          </div>
        </div>
      </section>

<section id="new" class="section new-section">
  <div class="new-card start-layout">

    <div class="start-copy">

      <p class="eyebrow">Start Here</p>

      <h2>Your first F3 workout starts here.</h2>

      <p>
        F3 is free, outdoors, peer-led, and open to all men. Show up
        10 minutes early and we'll take care of the rest.
      </p>

      <div class="new-grid">

        <div>
          <strong>Bring</strong>
          <span>Water, gloves, shoes, and a good attitude.</span>
        </div>

        <div>
          <strong>Arrive</strong>
          <span>Show up 10 minutes early and introduce yourself.</span>
        </div>

        <div>
          <strong>Expect</strong>
          <span>Rain or shine. Nobody gets left behind.</span>
        </div>

      </div>

      <a class="button primary" href="#today">
        Find Today's Workout
      </a>

    </div>

    <div class="start-video">

      <iframe
        src="https://player.vimeo.com/video/143444379?title=0&byline=0&portrait=0"
        allowfullscreen
      ></iframe>

    </div>

  </div>
</section>

<section id="today" class="section today-section" aria-labelledby="today-title">
  <div class="section-heading wide">
    <p class="eyebrow" id="today-eyebrow">Today</p>
    <h2 id="today-title">Where are you posting today?</h2>
    <p id="today-subtitle">Choose your region first, then pick a workout and show up 10 minutes early.</p>
  </div>

  <div class="today-region-picker" aria-label="Choose a region for today's workouts">
    {regions.map((region) => (
      <button
        class="today-region-button"
        type="button"
        data-today-region={region}
      >
        <span>{region}</span>
        <small>View workouts</small>
      </button>
    ))}
  </div>

  <div class="today-selected-row" id="todaySelectedRow" hidden>
    <p><strong id="todaySelectedRegion"></strong> workouts</p>
    <button class="today-clear-button" type="button" id="todayClearButton">Change region</button>
  </div>

  <div class="today-grid" id="todayGrid" hidden>
    {visibleAos.map((ao) => (
      <article
        class="today-card today-card-compact"
        data-region={ao.region}
        data-schedule={JSON.stringify(ao.schedule || [])}
        data-fallback-days={(ao.days || '').toLowerCase()}
        data-fallback-time={ao.time}
        data-fallback-map={ao.mapUrl || `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(ao.address)}`}
        data-fallback-address={ao.address}
        hidden
      >
        <div class="today-main">
          <span>{ao.type}</span>
          <h3>{ao.name}</h3>
          <p class="today-card-meta">{ao.region} • {ao.city} • {ao.time}</p>
        </div>
        <a
          class="map-link"
          href={ao.mapUrl || `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(ao.address)}`}
          target="_blank"
          rel="noreferrer"
        >
          Directions
        </a>
      </article>
    ))}
  </div>

  <p class="today-empty" id="todayEmpty" hidden>No listed workouts found for this region.</p>
</section>

      <section id="find" class="section finder" aria-labelledby="find-title">
        <div class="section-heading wide">
          <p class="eyebrow">AO Finder</p>
          <h2 id="find-title">Need something different?</h2>
          <p>Choose a region first. Then search by AO, city, day, location, or workout type.</p>
        </div>

        <div class="finder-region-picker" id="finderRegionPicker" aria-label="Choose a region for AO finder">
          {regions.map((region) => (
            <button
              class="finder-region-button"
              type="button"
              data-finder-region={region}
            >
              <span>{region}</span>
              <small>
                {visibleAos.filter((ao) => ao.region === region).length} AOs
              </small>
            </button>
          ))}
        </div>

        <div class="finder-active-panel" id="finderActivePanel" hidden>
          <div class="finder-active-header">
            <div>
              <p class="eyebrow">Selected Region</p>
              <h3 id="finderSelectedRegion">Lexington</h3>
              <p><span id="visibleCount">0</span> AO listings shown</p>
            </div>
            <button class="finder-back-button" type="button" id="finderBackButton">Back to regions</button>
          </div>

          <div class="controls finder-controls" role="search">
            <label class="search-box">
              <span class="sr-only">Search AOs</span>
              <input id="search" type="search" placeholder="Search AO, city, address, day, workout type..." />
            </label>
            <select id="typeFilter" aria-label="Filter by workout type">
              <option value="all">All workout types</option>
              {types.map((type) => <option value={type}>{type}</option>)}
            </select>
          </div>
        </div>

        <div class="ao-grid" id="aoGrid" hidden>
         {visibleAos.map((ao) => (
            <article
              class="ao-card"
              data-region={ao.region}
              data-type={ao.type}
              data-search={`${ao.name} ${ao.region} ${ao.city} ${ao.type} ${ao.days} ${ao.time} ${ao.address} ${ao.notes} ${ao.scheduleSummary || ''}`.toLowerCase()}
              id={ao.region.toLowerCase().replaceAll(' ', '-')}
              hidden
            >
              <div class="card-top">
                <span class="type-pill">{ao.type}</span>
                <span>{ao.region}</span>
              </div>
              <h3>{ao.name}</h3>
              <dl>
                <div><dt>When</dt><dd>{ao.days}<br />{ao.time}</dd></div>
                <div><dt>Where</dt><dd>{ao.address}</dd></div>
              </dl>
              <p>{ao.notes}</p>
              <a class="map-link" href={ao.mapUrl || `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(ao.address)}`} target="_blank" rel="noreferrer">Directions</a>
            </article>
          ))}
        </div>

        <p class="finder-empty" id="finderEmpty" hidden>No AOs match those filters in this region.</p>
      </section>
      <section id="contact" class="section contact-section" aria-labelledby="contact-title">
        <div class="contact-grid help-grid">
          <div>
            <p class="eyebrow">Need Help?</p>
            <h2 id="contact-title">Still not sure where to start?</h2>
            <p>Send us a note and a local PAX will help point you toward a good first workout. You can also use the official F3 Nation map to explore every listed AO nearby.</p>

            <div class="hero-actions help-actions">
              <a class="button primary" href="#contactForm">Send us a message</a>
              <a class="button ghost" href="https://map.f3nation.com/?lat=33.990100&lng=-81.252600&zoom=10" target="_blank" rel="noreferrer">Open official map</a>
            </div>
          </div>

          <form
            id="contactForm"
            class="contact-form"
            action="https://formsubmit.co/f3lexington@gmail.com"
            method="POST"
          >
            <input type="hidden" name="_subject" value="New F3 Midlands contact form submission" />
            <input type="hidden" name="_captcha" value="false" />
            <input type="hidden" name="_template" value="table" />
            <input type="hidden" name="_next" value="https://jamesshealy109-sudo.github.io/f3midlands/#contact" />

            <label>Name<input name="name" required /></label>
            <label>Email<input type="email" name="email" required /></label>
            <label>Message<textarea name="message" rows="4" required placeholder="Tell us where you live and what day you want to try." ></textarea></label>
            <button class="button primary" type="submit">Send message</button>
          </form>
        </div>
      </section>
    </main>

    <footer>
      <div class="footer-brand">
        <img src="/f3midlands/assets/f3-logo.png" alt="F3" />
        <span>F3 Midlands</span>
      </div>

      <div class="footer-links">
        <a
          class="social-link"
          href="https://www.facebook.com/F3LexSC/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Follow us on Facebook"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path fill="currentColor" d="M13.5 22v-8h2.7l.4-3h-3.1V9.1c0-.9.3-1.6 1.6-1.6H17V4.8c-.4-.1-1.3-.2-2.5-.2-2.5 0-4.2 1.5-4.2 4.4V11H7.5v3h2.8v8h3.2z"/>
          </svg>
        </a>

        <a href="#top">Back to top</a>
      </div>
    </footer>

    <script>
      const search = document.querySelector('#search');
      const typeFilter = document.querySelector('#typeFilter');
      const cards = [...document.querySelectorAll('.ao-card')];
      const visibleCount = document.querySelector('#visibleCount');
      const aoGrid = document.querySelector('#aoGrid');
      const finderRegionButtons = [...document.querySelectorAll('[data-finder-region]')];
      const finderActivePanel = document.querySelector('#finderActivePanel');
      const finderSelectedRegion = document.querySelector('#finderSelectedRegion');
      const finderBackButton = document.querySelector('#finderBackButton');
      const finderEmpty = document.querySelector('#finderEmpty');

      let selectedFinderRegion = '';

      function applyFilters() {
        const q = search?.value.trim().toLowerCase() || '';
        const type = typeFilter?.value || 'all';
        let visible = 0;

        cards.forEach((card) => {
          const matchesRegion = selectedFinderRegion && card.dataset.region === selectedFinderRegion;
          const matchesText = !q || card.dataset.search.includes(q);
          const matchesType = type === 'all' || card.dataset.type === type;
          const show = matchesRegion && matchesText && matchesType;

          card.hidden = !show;
          if (show) visible++;
        });

        if (visibleCount) visibleCount.textContent = visible;
        if (finderEmpty) finderEmpty.hidden = !selectedFinderRegion || visible !== 0;
      }

      function showFinderRegion(region) {
        selectedFinderRegion = region;

        finderRegionButtons.forEach((button) => {
          button.classList.toggle('is-active', button.dataset.finderRegion === region);
        });

        if (finderSelectedRegion) finderSelectedRegion.textContent = region;
        if (finderActivePanel) finderActivePanel.hidden = false;
        if (aoGrid) aoGrid.hidden = false;
        if (search) search.value = '';
        if (typeFilter) typeFilter.value = 'all';

        applyFilters();

        document.querySelector('#find')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }

      finderRegionButtons.forEach((button) => {
        button.addEventListener('click', () => showFinderRegion(button.dataset.finderRegion));
      });

      if (finderBackButton) {
        finderBackButton.addEventListener('click', () => {
          selectedFinderRegion = '';
          if (finderActivePanel) finderActivePanel.hidden = true;
          if (aoGrid) aoGrid.hidden = true;
          if (finderEmpty) finderEmpty.hidden = true;
          cards.forEach((card) => card.hidden = true);
          finderRegionButtons.forEach((button) => button.classList.remove('is-active'));
          document.querySelector('#find')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
      }

      [search, typeFilter].forEach((el) => {
        if (el) el.addEventListener('input', applyFilters);
      });
      });
const dayMap = {
  0: ['sun', 'sunday'],
  1: ['mon', 'monday'],
  2: ['tue', 'tuesday'],
  3: ['wed', 'wednesday'],
  4: ['thu', 'thursday'],
  5: ['fri', 'friday'],
  6: ['sat', 'saturday']
};

const dayNames = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
const todayCards = [...document.querySelectorAll('.today-card')];
const todayEmpty = document.querySelector('#todayEmpty');

      const todayTitleEl = document.querySelector('#today-title');
      const todayEyebrowEl = document.querySelector('#today-eyebrow');
      const todaySubtitleEl = document.querySelector('#today-subtitle');
      const todayGridEl = document.querySelector('#todayGrid');
      const todayCardsEl = [...document.querySelectorAll('.today-card')];
      const todayEmptyEl = document.querySelector('#todayEmpty');
      const todayRegionButtonsEl = [...document.querySelectorAll('[data-today-region]')];
      const todaySelectedRowEl = document.querySelector('#todaySelectedRow');
      const todaySelectedRegionEl = document.querySelector('#todaySelectedRegion');
      const todayClearButtonEl = document.querySelector('#todayClearButton');

      const todayDayNames = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
      const todayNow = new Date();
      const todayAfterCutoff = todayNow.getHours() >= 7;
      const todayTargetDate = new Date(todayNow);
      if (todayAfterCutoff) todayTargetDate.setDate(todayTargetDate.getDate() + 1);
      const todayTargetDay = todayDayNames[todayTargetDate.getDay()];

      if (todayTitleEl) {
        todayTitleEl.textContent = todayAfterCutoff ? 'Where are you posting tomorrow?' : 'Where are you posting today?';
      }

      if (todayEyebrowEl) {
        todayEyebrowEl.textContent = todayAfterCutoff ? 'Tomorrow' : 'Today';
      }

      if (todaySubtitleEl) {
        todaySubtitleEl.textContent = `Choose a region to see ${todayTargetDay}'s workouts.`;
      }

      function getScheduleForTargetDay(card) {
        try {
          const schedule = JSON.parse(card.dataset.schedule || '[]');
          return schedule.find((item) => String(item.day || '').toLowerCase() === todayTargetDay.toLowerCase());
        } catch {
          return null;
        }
      }

      function showTodayRegion(region) {
        let visible = 0;

        todayRegionButtonsEl.forEach((button) => {
          button.classList.toggle('is-active', button.dataset.todayRegion === region);
        });

        if (todayGridEl) todayGridEl.hidden = false;
        if (todaySelectedRowEl) todaySelectedRowEl.hidden = false;
        if (todaySelectedRegionEl) todaySelectedRegionEl.textContent = region;

        todayCardsEl.forEach((card) => {
          const regionMatch = card.dataset.region === region;
          const slot = getScheduleForTargetDay(card);
          const fallbackDayMatch = (card.dataset.fallbackDays || '').includes(todayTargetDay.toLowerCase());
          const show = regionMatch && (slot || fallbackDayMatch);

          card.hidden = !show;

          if (show) {
            visible++;

            const meta = card.querySelector('.today-card-meta');
            const link = card.querySelector('.map-link');
            const title = card.querySelector('h3')?.textContent || 'workout';

            const time = slot?.time || card.dataset.fallbackTime || '';
            const city = slot?.city || '';
            const location = slot?.location || '';
            const mapUrl = slot?.mapUrl || card.dataset.fallbackMap || link?.href;

            if (meta) {
              meta.textContent = [card.dataset.region, city, time, location].filter(Boolean).join(' • ');
            }

            if (link && mapUrl) {
              link.href = mapUrl;
              link.setAttribute('aria-label', `Directions to ${title}`);
            }
          }
        });

        if (todayEmptyEl) todayEmptyEl.hidden = visible !== 0;
      }

      todayRegionButtonsEl.forEach((button) => {
        button.addEventListener('click', () => showTodayRegion(button.dataset.todayRegion));
      });

      if (todayClearButtonEl) {
        todayClearButtonEl.addEventListener('click', () => {
          if (todayGridEl) todayGridEl.hidden = true;
          if (todayEmptyEl) todayEmptyEl.hidden = true;
          if (todaySelectedRowEl) todaySelectedRowEl.hidden = true;
          todayCardsEl.forEach((card) => card.hidden = true);
          todayRegionButtonsEl.forEach((button) => button.classList.remove('is-active'));
          document.querySelector('#today')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
      }

    </script>
  </body>
</html>
