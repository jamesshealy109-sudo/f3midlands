---
import '../styles/global.css';
import aos from '../data/aos.json';

const base = import.meta.env.BASE_URL;
const regions = ['Lexington', 'Columbia', 'Lake Murray', 'Camden', 'Saluda'];
const regionCounts = regions.map((region) => ({
  region,
  count: aos.filter((ao) => ao.region === region).length,
  types: [...new Set(aos.filter((ao) => ao.region === region).map((ao) => ao.type.split('/')[0].trim()))].slice(0, 4)
}));
const allTypes = [...new Set(aos.map((ao) => ao.type.split('/')[0].trim()))].sort();
const totalAos = aos.length;
const mapUrl = 'https://f3near.me/nearby';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="F3 Midlands: free outdoor workouts for men across Lexington, Columbia, Lake Murray, Camden, and Saluda." />
    <link rel="icon" type="image/png" href={`${base}favicon.png`} />
    <title>F3 Midlands | Free Outdoor Workouts for Men</title>
  </head>
  <body>
    <header class="site-header" id="top">
      <a class="brand" href="#top" aria-label="F3 Midlands home">
        <img src={`${base}assets/f3-logo.png`} alt="F3" />
        <span>F3 Midlands</span>
      </a>
      <nav class="nav" aria-label="Primary navigation">
        <a href="#find">Find an AO</a>
        <a href="#new">I'm New</a>
        <a href="#regions">Regions</a>
        <a href="#video">Video</a>
        <a href="#contact">Contact</a>
      </nav>
      <a class="header-cta" href="#find">Find Your AO</a>
    </header>

    <main>
      <section class="hero">
        <div class="hero-bg" aria-hidden="true"></div>
        <div class="hero-grid" aria-hidden="true"></div>
        <div class="hero-content">
          <img class="hero-mark" src={`${base}assets/f3-logo.png`} alt="F3" />
          <p class="eyebrow">Lexington · Columbia · Lake Murray · Camden · Saluda</p>
          <h1>Free Outdoor Workouts for Men</h1>
          <p class="hero-copy">No fees. No signups. No excuses. Just show up and get better with men in your community.</p>
          <div class="hero-actions">
            <a class="btn primary" href="#find">Find Your AO</a>
            <a class="btn ghost" href="#new">Start Here</a>
          </div>
          <div class="stats" aria-label="F3 Midlands stats">
            <div><strong>{totalAos}</strong><span>AO listings</span></div>
            <div><strong>{regions.length}</strong><span>Regions</span></div>
            <div><strong>$0</strong><span>Always free</span></div>
            <div><strong>365</strong><span>Rain or shine</span></div>
          </div>
        </div>
      </section>

      <section class="section intro-strip" aria-label="F3 core principles">
        <div class="principle"><span>01</span><strong>Free of charge</strong></div>
        <div class="principle"><span>02</span><strong>Open to all men</strong></div>
        <div class="principle"><span>03</span><strong>Outdoors, rain or shine</strong></div>
        <div class="principle"><span>04</span><strong>Peer led</strong></div>
        <div class="principle"><span>05</span><strong>Ends in a COT</strong></div>
      </section>

      <section class="section" id="regions">
        <div class="section-heading">
          <p class="eyebrow">Choose your side of the Midlands</p>
          <h2>Regions built around where you live, work, and launch your day.</h2>
        </div>
        <div class="region-grid">
          {regionCounts.map(({ region, count, types }) => (
            <article class="region-card" data-region-jump={region}>
              <div>
                <p class="eyebrow">F3 {region}</p>
                <h3>{region}</h3>
                <p>{count} AO {count === 1 ? 'listing' : 'listings'}</p>
              </div>
              <div class="type-row">
                {types.map((type) => <span>{type}</span>)}
              </div>
              <a href="#find" class="text-link">View region →</a>
            </article>
          ))}
        </div>
      </section>

      <section class="section map-section" id="map">
        <div class="map-copy">
          <p class="eyebrow">Map powered by F3NearMe</p>
          <h2>Open the live AO map.</h2>
          <p>Use the official finder to see nearby workout pins, confirm distance, and launch directions from your current location.</p>
          <div class="map-actions">
            <a class="btn primary" href={mapUrl} target="_blank" rel="noopener">Open F3NearMe Map</a>
            <a class="btn ghost" href="#find">Browse AO List</a>
          </div>
        </div>
        <div class="map-panel" aria-label="F3NearMe map preview">
          <div class="map-toolbar">
            <span>F3NearMe</span>
            <strong>Nearby AO Finder</strong>
          </div>
          <iframe
            src={mapUrl}
            title="F3NearMe nearby AO map"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </section>

      <section class="section finder" id="find">
        <div class="section-heading wide">
          <p class="eyebrow">Find your first post</p>
          <h2>Search every AO listing in the Midlands.</h2>
          <p>Filter by region, workout style, or day. Columbia details are intentionally marked where a local schedule needs confirmation.</p>
        </div>

        <div class="finder-controls" role="search">
          <label class="search-box">
            <span>Search AOs</span>
            <input id="aoSearch" type="search" placeholder="Search by AO, city, type, or notes" autocomplete="off" />
          </label>
          <label>
            <span>Region</span>
            <select id="regionFilter">
              <option value="All">All regions</option>
              {regions.map((region) => <option value={region}>{region}</option>)}
            </select>
          </label>
          <label>
            <span>Type</span>
            <select id="typeFilter">
              <option value="All">All types</option>
              {allTypes.map((type) => <option value={type}>{type}</option>)}
            </select>
          </label>
          <label>
            <span>Day</span>
            <select id="dayFilter">
              <option value="All">Any day</option>
              {['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'].map((day) => <option value={day}>{day}</option>)}
            </select>
          </label>
        </div>

        <div class="result-meta">
          <strong id="resultCount">{totalAos}</strong>
          <span>AO listings shown</span>
        </div>
        <div class="ao-grid" id="aoGrid">
          {aos.map((ao) => {
            const searchable = `${ao.name} ${ao.region} ${ao.type} ${ao.address} ${ao.notes} ${ao.days.join(' ')}`.toLowerCase();
            const directions = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(ao.address)}`;
            return (
              <article class="ao-card" data-search={searchable} data-region={ao.region} data-type={ao.type.split('/')[0].trim()} data-days={ao.days.join(',')}>
                <div class="ao-topline">
                  <span class="pill">{ao.region}</span>
                  <span class="pill muted">{ao.type}</span>
                </div>
                <h3>{ao.name}</h3>
                <p class="time">{ao.time}</p>
                <p class="days">{ao.days.length ? ao.days.join(' · ') : 'Schedule needs confirmation'}</p>
                <p class="address">{ao.address}</p>
                {ao.notes && <p class="notes">{ao.notes}</p>}
                {ao.sourceStatus.includes('incomplete') && <p class="needs-confirmation">Details need local confirmation</p>}
                <div class="card-actions">
                  <a href={directions} target="_blank" rel="noopener">Directions</a>
                </div>
              </article>
            );
          })}
        </div>
      </section>

      <section class="section new-section" id="new">
        <div class="new-card">
          <div>
            <p class="eyebrow">New to F3?</p>
            <h2>Perfect. You do not need to be in shape to start.</h2>
            <p>Show up a few minutes early. Bring water, gloves if you have them, and a willingness to work. The men there will take care of the rest.</p>
          </div>
          <div class="steps">
            <div><span>1</span><strong>Pick an AO</strong><p>Choose the closest workout that matches your morning.</p></div>
            <div><span>2</span><strong>Show up</strong><p>No signup. No payment. No experience required.</p></div>
            <div><span>3</span><strong>Stick around</strong><p>Every workout ends with a Circle of Trust.</p></div>
          </div>
        </div>
      </section>

      <section class="section video-section" id="video">
        <div class="section-heading">
          <p class="eyebrow">See F3 in action</p>
          <h2>A few minutes tells the story better than a paragraph.</h2>
        </div>
        <div class="video-frame">
          <iframe
            src="https://player.vimeo.com/video/143444379?title=0&byline=0&portrait=0&badge=0&autopause=0&player_id=0&app_id=58479"
            title="F3 video"
            allow="autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share"
            allowfullscreen
          ></iframe>
        </div>
      </section>

      <section class="section contact-section" id="contact">
        <div class="section-heading">
          <p class="eyebrow">Reach out</p>
          <h2>Questions before you post?</h2>
          <p>Send a note and someone from the region can help point you to the right AO.</p>
        </div>
        <form class="contact-form" id="contactForm">
          <label>
            <span>Name</span>
            <input name="name" required placeholder="Your name" />
          </label>
          <label>
            <span>Email</span>
            <input name="email" type="email" required placeholder="you@example.com" />
          </label>
          <label>
            <span>Region</span>
            <select name="region">
              {regions.map((region) => <option value={region}>{region}</option>)}
              <option value="Not sure">Not sure yet</option>
            </select>
          </label>
          <label class="full">
            <span>Message</span>
            <textarea name="message" rows="5" required placeholder="Tell us where you are and what morning works best."></textarea>
          </label>
          <button class="btn primary" type="submit">Send Message</button>
          <p class="form-status" id="formStatus" aria-live="polite"></p>
        </form>
      </section>
    </main>

    <footer class="footer">
      <img src={`${base}assets/f3-logo.png`} alt="F3" />
      <p>F3 Midlands</p>
      <a href="#top">Back to top ↑</a>
    </footer>

    <script is:inline>
      const aoSearch = document.querySelector('#aoSearch');
      const regionFilter = document.querySelector('#regionFilter');
      const typeFilter = document.querySelector('#typeFilter');
      const dayFilter = document.querySelector('#dayFilter');
      const cards = [...document.querySelectorAll('.ao-card')];
      const resultCount = document.querySelector('#resultCount');
      const form = document.querySelector('#contactForm');
      const formStatus = document.querySelector('#formStatus');

      function updateFilters() {
        const q = aoSearch.value.trim().toLowerCase();
        const region = regionFilter.value;
        const type = typeFilter.value;
        const day = dayFilter.value;
        let count = 0;
        cards.forEach((card) => {
          const matchesSearch = !q || card.dataset.search.includes(q);
          const matchesRegion = region === 'All' || card.dataset.region === region;
          const matchesType = type === 'All' || card.dataset.type === type;
          const matchesDay = day === 'All' || card.dataset.days.includes(day);
          const show = matchesSearch && matchesRegion && matchesType && matchesDay;
          card.hidden = !show;
          if (show) count += 1;
        });
        resultCount.textContent = count;
      }

      [aoSearch, regionFilter, typeFilter, dayFilter].forEach((el) => el.addEventListener('input', updateFilters));

      document.querySelectorAll('[data-region-jump]').forEach((card) => {
        card.addEventListener('click', () => {
          regionFilter.value = card.dataset.regionJump;
          updateFilters();
          document.querySelector('#find').scrollIntoView({ behavior: 'smooth' });
        });
      });

      form.addEventListener('submit', (event) => {
        event.preventDefault();
        const data = Object.fromEntries(new FormData(form).entries());
        const subject = encodeURIComponent(`F3 Midlands question from ${data.name}`);
        const body = encodeURIComponent(`Name: ${data.name}\nEmail: ${data.email}\nRegion: ${data.region}\n\n${data.message}`);
        formStatus.innerHTML = `Thanks, ${data.name}. Your message is ready. <a href="mailto:f3lexington@gmail.com?subject=${subject}&body=${body}">Open email app</a>`;
        form.reset();
      });
    </script>
  </body>
</html>
